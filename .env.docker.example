# Hermes Agent - Docker Deployment Configuration
# Copy to .env and fill in your values

# Required: OpenRouter API Key
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Container naming
CONTAINER_NAME=hermes-agent
VOLUME_NAME=hermes_data

# Agent identity
AGENT_NAME=Hermes
MODEL=openrouter:moonshotai/kimi-k2.5
MAX_TURNS=60

# UX Settings (clean for production)
TOOL_PROGRESS=off
SHOW_REASONING=false

# WhatsApp Settings
WHATSAPP_ENABLED=true
WHATSAPP_MODE=bot
# The phone number(s) allowed to use the bot (comma-separated, international format)
WHATSAPP_ALLOWED_USERS=+56912345678
WHATSAPP_DEBUG=true

# Gateway
GATEWAY_ALLOW_ALL_USERS=false
