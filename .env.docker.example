# =============================================================================
# HERMES AGENT - DOCKER DEPLOYMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# Then run: docker-compose up -d
#
# For mass deployment, create a separate .env file per client with unique
# WHATSAPP_SESSION_NAME and WHATSAPP_ALLOWED_USERS
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: API Keys
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# CLIENT IDENTITY
# -----------------------------------------------------------------------------
# Unique name for this agent instance (shows in responses)
AGENT_NAME=Tiamat

# Container and volume naming (unique per deployment)
CONTAINER_NAME=hermes-cliente-a
VOLUME_NAME=hermes_data_cliente_a

# -----------------------------------------------------------------------------
# WHATSAPP CONFIGURATION (AUTO-PAIRING ENABLED)
# -----------------------------------------------------------------------------
# CRITICAL: Must be unique per client/deployment
# Format: lowercase letters, numbers, hyphens only
WHATSAPP_SESSION_NAME=cliente-a-session

# Mode: "bot" (separate number) or "self-chat" (your own number)
WHATSAPP_MODE=bot

# Allowed phone numbers (comma-separated, international format)
# Example: +56912345678,+56987654321
WHATSAPP_ALLOWED_USERS=+56900000000

# -----------------------------------------------------------------------------
# MODEL CONFIGURATION
# -----------------------------------------------------------------------------
# Default model via OpenRouter
MODEL=openrouter:moonshotai/kimi-k2.5

# Max conversation turns before reset (prevents runaway costs)
MAX_TURNS=60

# -----------------------------------------------------------------------------
# USER EXPERIENCE (Keep clean for clients)
# -----------------------------------------------------------------------------
# Hide technical details
TOOL_PROGRESS=off
SHOW_REASONING=false

# -----------------------------------------------------------------------------
# OPTIONAL: DEBUG
# -----------------------------------------------------------------------------
# Enable WhatsApp debug logging
WHATSAPP_DEBUG=false

# Allow all users (not recommended for production)
GATEWAY_ALLOW_ALL_USERS=false
