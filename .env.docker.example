# Hermes Agent - Environment Variables
# Copy to .env and configure�_as needed

# =============================================================================
# REQUIRED API KEYS
# =============================================================================
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# HERMES CONFIGURATION
# =============================================================================
HERMES_HOME=/opt/data
HERMES_MODEL=openrouter:moonshotai/kimi-k2.5
AGENT_NAME=Tiamat
MAX_TURNS=60
TOOL_PROGRESS=off
SHOW_REASONING=false
TERMINAL_TIMEOUT=300
TERMINAL_ENV=docker

# =============================================================================
# WHATSAPP CONFIGURATION (CRITICAL for WhatsApp to work)
# =============================================================================
# Must be set to "true" for WhatsApp to be enabled
WHATSAPP_ENABLED=true

# Mode: "self-chat" (your own number) or "bot" (dedicated number)
WHATSAPP_MODE=self-chat

# Your phone number WITHOUT the + (e.g., 56912345678 for Chile)
WHATSAPP_ALLOWED_USERS=56912345678

# Set to "true" for verbose logging during troubleshooting
WHATSAPP_DEBUG=false

# =============================================================================
# GATEWAY CONFIGURATION
# =============================================================================
WHATSAPP_HOME_CHANNEL=
GATEWAY_ALLOW_ALL_USERS=false

# =============================================================================
# OPTIONAL API KEYS (configure as needed)
# =============================================================================
GROQ_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
FAL_KEY=

# =============================================================================
# CONTEXT & MEMORY
# =============================================================================
CONTEXT_COMPRESSION_ENABLED=true
